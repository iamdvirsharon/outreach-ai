# ─── Database (Supabase PostgreSQL) ───
# Create a free project at https://supabase.com
# Go to Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── Bright Data API (LinkedIn datasets) ───
# Get your API key from Bright Data dashboard
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_POSTS_DATASET=gd_lyy3tktm25m4avu764
BRIGHT_DATA_COMMENTS_DATASET=gd_s2s1us1i1kj1oydz17
BRIGHT_DATA_PROFILES_DATASET=gd_l1viktl72bvl7bjuj0
# Optional: enables capturing post likers (5-10x more leads)
BRIGHT_DATA_LIKERS_DATASET=
# Optional: enables auto-discovering company employees
BRIGHT_DATA_COMPANY_DATASET=
# Required for YouTube comment scraping
BRIGHT_DATA_YOUTUBE_COMMENTS_DATASET=

# ─── Enrichment Providers ───
# Configure at least one provider for people enrichment
APOLLO_API_KEY=
ZOOMINFO_CLIENT_ID=
ZOOMINFO_PRIVATE_KEY=
LEADIQ_API_KEY=

# ─── Anthropic Claude API ───
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Google Sheets (Service Account) ───
# 1. Create service account at https://console.cloud.google.com
# 2. Download JSON key
# 3. Share your target spreadsheet with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_SHEET_ID=

# ─── Auth Passwords ───
# Admin: full access (configure companies, employees, trigger scrapes, export)
# Viewer: read-only (dashboard, engagers list, outreach drafts)
ADMIN_PASSWORD=change-this
VIEWER_PASSWORD=change-this-too

# ─── Internal Security ───
INTERNAL_API_KEY=change-this-to-a-random-string
CRON_SECRET=your-vercel-cron-secret

# ─── App URL ───
# Set automatically by Vercel (VERCEL_URL). Override for local dev:
APP_URL=http://localhost:3000

# ─── Note ───
# No artificial limits — Bright Data API is used without caps
